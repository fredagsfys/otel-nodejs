{
  "name": "otel-nodejs",
  "version": "1.0.0",
  "description": "Idiomatic OpenTelemetry template for Node.js using zero-code auto-instrumentation",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "OTEL_SERVICE_NAME=greeting-service OTEL_SEMCONV_STABILITY_OPT_IN=http node --require @opentelemetry/auto-instrumentations-node/register dist/server.js",
    "dev": "OTEL_SERVICE_NAME=greeting-service OTEL_SEMCONV_STABILITY_OPT_IN=http NODE_OPTIONS=\"--require @opentelemetry/auto-instrumentations-node/register\" tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stack": "docker compose -f observability/docker-compose.yaml up -d",
    "stack:down": "docker compose -f observability/docker-compose.yaml down"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/winston-transport": "^0.28.0",
    "express": "^5.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
